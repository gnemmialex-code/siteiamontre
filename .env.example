# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (créer dans Stripe Dashboard)
STRIPE_PRICE_50_CREDITS=price_
STRIPE_PRICE_150_CREDITS=price_
STRIPE_PRICE_400_CREDITS=price_

# Replicate (pipeline IA)
REPLICATE_API_TOKEN=r8_your-replicate-api-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_SECRET_KEY=your-random-secret-key-min-32-chars

# Upload
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
